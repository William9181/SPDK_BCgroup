+ */
+
+#ifndef SPDK_VBDEV_BCGROUP_H
+#define SPDK_VBDEV_BCGROUP_H
+
+#include "spdk/stdinc.h"
+#include "spdk/bdev.h"
+#include "spdk/bdev_module.h"
+
+struct vbdev_bcgroup {
+    struct spdk_bdev        *base_bdev; 
+    struct spdk_bdev_desc   *base_desc; 
+    struct spdk_bdev        mq_bdev;    
+    TAILQ_ENTRY(vbdev_bcgroup) link;
+    struct spdk_thread      *thread;    
+
+    uint64_t config_target_lat_us; 
+    uint64_t measured_avg_latency; 
+    uint64_t config_weight; 
+    uint64_t measured_iops;
+    uint64_t current_run_limit;
+
+    uint64_t total_rbytes;
+    uint64_t total_wbytes;
+    uint64_t total_rios;
+    uint64_t total_wios;
+    uint64_t pressure_ticks;
+    uint64_t total_ticks;
+};                        
+TAILQ_HEAD(mq_node_list, vbdev_bcgroup);        
+extern struct mq_node_list g_mq_nodes;        
+
+
+int bdev_bcgroup_create_disk(const char *bdev_name, const char *vbdev_name,
+			      const struct spdk_uuid *uuid);
+
+void bdev_bcgroup_delete_disk(const char *bdev_name, spdk_bdev_unregister_cb cb_fn,
+			       void *cb_arg);
+
+/* register RPC */
+void bcgroup_rpc_register(void);
+
+
+#endif /* SPDK_VBDEV_BCGROUP_H */
