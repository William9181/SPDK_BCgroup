+static void
+vbdev_bcgroup_base_bdev_hotremove_cb(struct spdk_bdev *bdev_find)
+{
+	struct vbdev_bcgroup *mq_node, *tmp;
+
+	TAILQ_FOREACH_SAFE(mq_node, &g_mq_nodes, link, tmp) {
+		if (bdev_find == mq_node->base_bdev) {
+			spdk_bdev_unregister(&mq_node->mq_bdev, NULL, NULL);
+		}
+	}
+}
+
+/* Called when the underlying base bdev triggers asynchronous event such as bdev removal. */
+static void
+vbdev_bcgroup_base_bdev_event_cb(enum spdk_bdev_event_type type, struct spdk_bdev *bdev,
+				  void *event_ctx)
+{
+	switch (type) {
+	case SPDK_BDEV_EVENT_REMOVE:
+		vbdev_bcgroup_base_bdev_hotremove_cb(bdev);
+		break;
+	default:
+		SPDK_NOTICELOG("Unsupported bdev event: type %d\n", type);
+		break;
+	}
+}
+
+/* Create and register the bcgroup vbdev if we find it in our list of bdev names.
+ * This can be called either by the examine path or RPC method.
+ */
+static int
+vbdev_bcgroup_register(const char *bdev_name)
+{
+	struct bdev_names *name;
+	struct vbdev_bcgroup *mq_node;
+	struct spdk_bdev *bdev;
+	struct spdk_uuid ns_uuid;
+	int rc = 0;
+
+	spdk_uuid_parse(&ns_uuid, BDEV_BCGROUP_NAMESPACE_UUID);
+
+	/* Check our list of names from config versus this bdev and if
+	 * there's a match, create the mq_node & bdev accordingly.
+	 */
+	TAILQ_FOREACH(name, &g_bdev_names, link) {
+		if (strcmp(name->bdev_name, bdev_name) != 0) {
+			continue;
+		}
+
+		SPDK_NOTICELOG("Match on %s\n", bdev_name);
+		mq_node = calloc(1, sizeof(struct vbdev_bcgroup));
+		if (!mq_node) {
+			rc = -ENOMEM;
+			SPDK_ERRLOG("could not allocate mq_node\n");
+			break;
+		}
+
+		mq_node->mq_bdev.name = strdup(name->vbdev_name);
+		if (!mq_node->mq_bdev.name) {
+			rc = -ENOMEM;
+			SPDK_ERRLOG("could not allocate mq_bdev name\n");
+			free(mq_node);
+			break;
+		}
+		mq_node->mq_bdev.product_name = "bcgroup";
+
+		/* The base bdev that we're attaching to. */
+		rc = spdk_bdev_open_ext(bdev_name, true, vbdev_bcgroup_base_bdev_event_cb,
+					NULL, &mq_node->base_desc);
+		if (rc) {
+			if (rc != -ENODEV) {
+				SPDK_ERRLOG("could not open bdev %s\n", bdev_name);
+			}
+			free(mq_node->mq_bdev.name);
+			free(mq_node);
+			break;
+		}
+		SPDK_NOTICELOG("base bdev opened\n");
+
+		bdev = spdk_bdev_desc_get_bdev(mq_node->base_desc);
+		mq_node->base_bdev = bdev;
+
+		if (!spdk_uuid_is_null(&name->uuid)) {
+			/* Use the configured UUID */
+			spdk_uuid_copy(&mq_node->mq_bdev.uuid, &name->uuid);
+		} else {
+			/* Generate UUID based on namespace UUID + base bdev UUID. */
+			rc = spdk_uuid_generate_sha1(&mq_node->mq_bdev.uuid, &ns_uuid,
+						     (const char *)&mq_node->base_bdev->uuid, sizeof(struct spdk_uuid));
+			if (rc) {
+				SPDK_ERRLOG("Unable to generate new UUID for bcgroup bdev\n");
+				spdk_bdev_close(mq_node->base_desc);
+				free(mq_node->mq_bdev.name);
+				free(mq_node);
+				break;
+			}
+		}
+
+		/* Copy some properties from the underlying base bdev. */
+		mq_node->mq_bdev.write_cache = bdev->write_cache;
+		mq_node->mq_bdev.required_alignment = bdev->required_alignment;
+		mq_node->mq_bdev.optimal_io_boundary = bdev->optimal_io_boundary;
+		mq_node->mq_bdev.blocklen = bdev->blocklen;
+		mq_node->mq_bdev.blockcnt = bdev->blockcnt;
+
+		mq_node->mq_bdev.md_interleave = bdev->md_interleave;
+		mq_node->mq_bdev.md_len = bdev->md_len;
+		mq_node->mq_bdev.dif_type = bdev->dif_type;
+		mq_node->mq_bdev.dif_is_head_of_md = bdev->dif_is_head_of_md;
+		mq_node->mq_bdev.dif_check_flags = bdev->dif_check_flags;
+		mq_node->mq_bdev.dif_pi_format = bdev->dif_pi_format;
+
+		/* This is the context that is passed to us when the bdev
+		 * layer calls in so we'll save our mq_bdev node here.
+		 */
+		mq_node->mq_bdev.ctxt = mq_node;
+		mq_node->mq_bdev.fn_table = &vbdev_bcgroup_fn_table;
+		mq_node->mq_bdev.module = &bcgroup_if;
+		TAILQ_INSERT_TAIL(&g_mq_nodes, mq_node, link);
+
+		spdk_io_device_register(mq_node, mq_bdev_ch_create_cb, mq_bdev_ch_destroy_cb,
+					sizeof(struct mq_io_channel),
+					name->vbdev_name);
+		SPDK_NOTICELOG("io_device created at: 0x%p\n", mq_node);
+
+		/* Save the thread where the base device is opened */
+		mq_node->thread = spdk_get_thread();
+
+		rc = spdk_bdev_module_claim_bdev(bdev, mq_node->base_desc, mq_node->mq_bdev.module);
+		if (rc) {
+			SPDK_ERRLOG("could not claim bdev %s\n", bdev_name);
+			spdk_bdev_close(mq_node->base_desc);
+			TAILQ_REMOVE(&g_mq_nodes, mq_node, link);
+			spdk_io_device_unregister(mq_node, NULL);
+			free(mq_node->mq_bdev.name);
+			free(mq_node);
+			break;
+		}
+		SPDK_NOTICELOG("bdev claimed\n");
+
+		rc = spdk_bdev_register(&mq_node->mq_bdev);
+		if (rc) {
+			SPDK_ERRLOG("could not register mq_bdev\n");
+			spdk_bdev_module_release_bdev(&mq_node->mq_bdev);
+			spdk_bdev_close(mq_node->base_desc);
+			TAILQ_REMOVE(&g_mq_nodes, mq_node, link);
+			spdk_io_device_unregister(mq_node, NULL);
+			free(mq_node->mq_bdev.name);
+			free(mq_node);
+			break;
+		}
+		SPDK_NOTICELOG("mq_bdev registered\n");
+		SPDK_NOTICELOG("created mq_bdev for: %s\n", name->vbdev_name);
+	}
+
+	return rc;
+}
+
+/* Create the bcgroup disk from the given bdev and vbdev name. */
+int
+bdev_bcgroup_create_disk(const char *bdev_name, const char *vbdev_name,
+			  const struct spdk_uuid *uuid)
+{
+	int rc;
+
+	/* Insert the bdev name into our global name list even if it doesn't exist yet,
+	 * it may show up soon...
+	 */
+	rc = vbdev_bcgroup_insert_name(bdev_name, vbdev_name, uuid);
+	if (rc) {
+		return rc;
+	}
+
+	rc = vbdev_bcgroup_register(bdev_name);
+	if (rc == -ENODEV) {
+		/* This is not an error, we tracked the name above and it still
+		 * may show up later.
+		 */
+		SPDK_NOTICELOG("vbdev creation deferred pending base bdev arrival\n");
+		rc = 0;
+	}
+
+	return rc;
+}
+
+void
+bdev_bcgroup_delete_disk(const char *bdev_name, spdk_bdev_unregister_cb cb_fn, void *cb_arg)
+{
+	struct bdev_names *name;
+	int rc;
+
+	/* Some cleanup happens in the destruct callback. */
+	rc = spdk_bdev_unregister_by_name(bdev_name, &bcgroup_if, cb_fn, cb_arg);
+	if (rc == 0) {
+		/* Remove the association (vbdev, bdev) from g_bdev_names. This is required so that the
+		 * vbdev does not get re-created if the same bdev is constructed at some other time,
+		 * unless the underlying bdev was hot-removed.
+		 */
+		TAILQ_FOREACH(name, &g_bdev_names, link) {
+			if (strcmp(name->vbdev_name, bdev_name) == 0) {
+				TAILQ_REMOVE(&g_bdev_names, name, link);
+				free(name->bdev_name);
+				free(name->vbdev_name);
+				free(name);
+				break;
+			}
+		}
+	} else {
+		cb_fn(cb_arg, rc);
+	}
+}
+
+/* Because we specified this function in our pt bdev function table when we
+ * registered our pt bdev, we'll get this call anytime a new bdev shows up.
+ * Here we need to decide if we care about it and if so what to do. We
+ * parsed the config file at init so we check the new bdev against the list
+ * we built up at that time and if the user configured us to attach to this
+ * bdev, here's where we do it.
+ */
+// 0223 : for fio delete
+static void
+vbdev_bcgroup_examine(struct spdk_bdev *bdev)
+{
+	vbdev_bcgroup_register(bdev->name);
+
+	spdk_bdev_module_examine_done(&bcgroup_if);
+}
+
+SPDK_LOG_REGISTER_COMPONENT(vbdev_bcgroup)
