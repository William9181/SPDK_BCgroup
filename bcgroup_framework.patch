diff --git a/bcgroup_rpc.py b/bcgroup_rpc.py
new file mode 100644
index 000000000..d93395c4f
--- /dev/null
+++ b/bcgroup_rpc.py
@@ -0,0 +1,81 @@
+import socket
+import json
+import sys
+
+def auto_type(value):
+    """
+    自動判斷參數類型 (Int, Float, Bool, String)
+    避免所有參數都被當成字串傳送。
+    """
+    # 嘗試轉為整數
+    try:
+        return int(value)
+    except ValueError:
+        pass
+
+    # 嘗試轉為浮點數
+    try:
+        return float(value)
+    except ValueError:
+        pass
+
+    # 嘗試轉為布林值
+    if value.lower() == "true":
+        return True
+    if value.lower() == "false":
+        return False
+
+    # 默認為字串
+    return value
+
+def send_request(method, params):
+    sock_path = "/var/tmp/spdk.sock"
+    request = {
+        "jsonrpc": "2.0",
+        "method": method,
+        "params": params,
+        "id": 1
+    }
+    
+    print(f"[Sending] Method: {method}")
+    print(f"[Params]  {json.dumps(params, indent=2)}")
+
+    try:
+        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
+            s.connect(sock_path)
+            s.sendall(json.dumps(request).encode('utf-8'))
+            response = s.recv(8192) # 接收更多資料
+            
+            # 解析並美化輸出
+            res_json = json.loads(response.decode('utf-8'))
+            
+            if 'error' in res_json:
+                print("\n❌ ERROR RESPONSE:")
+                print(json.dumps(res_json['error'], indent=2))
+                sys.exit(1)
+            else:
+                print("\n✅ SUCCESS RESULT:")
+                print(json.dumps(res_json['result'], indent=2))
+                
+    except Exception as e:
+        print(f"Connection Error: {e}")
+        sys.exit(1)
+
+if __name__ == "__main__":
+    if len(sys.argv) < 2:
+        print("Usage: python3 bcgroup_rpc.py <method_name> [param1=value1] [param2=value2] ...")
+        print("Example: python3 bcgroup_rpc.py bdev_bcgroup_create base_bdev_name=Malloc0 name=QoS0")
+        sys.exit(1)
+
+    method_name = sys.argv[1]
+    raw_args = sys.argv[2:]
+    
+    params = {}
+    for arg in raw_args:
+        if '=' in arg:
+            key, value = arg.split('=', 1)
+            params[key] = auto_type(value)
+        else:
+            print(f"Warning: Ignoring invalid argument '{arg}'. Format should be key=value")
+
+    send_request(method_name, params)
