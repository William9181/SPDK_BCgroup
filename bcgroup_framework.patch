+/* SPDX-License-Identifier: BSD-3-Clause
+ * Copyright (C) 2018 Intel Corporation.
+ * Copyright (c) 2023 NVIDIA CORPORATION & AFFILIATES. All rights reserved.
+ * All rights reserved.
+ */
+
+#include "vbdev_bcgroup.h"
+#include "spdk/rpc.h"
+#include "spdk/util.h"
+#include "spdk/string.h"
+#include "spdk/log.h"
+
+/* Log Component */
+SPDK_LOG_REGISTER_COMPONENT(bcgroup_rpc)
+
+struct rpc_bdev_bcgroup_create {
+	char *base_bdev_name;
+	char *name;
+	struct spdk_uuid uuid;
+};
+
+static void
+free_rpc_bdev_bcgroup_create(struct rpc_bdev_bcgroup_create *r)
+{
+	free(r->base_bdev_name);
+	free(r->name);
+}
+
+static const struct spdk_json_object_decoder rpc_bdev_bcgroup_create_decoders[] = {
+	{"base_bdev_name", offsetof(struct rpc_bdev_bcgroup_create, base_bdev_name), spdk_json_decode_string},
+	{"name", offsetof(struct rpc_bdev_bcgroup_create, name), spdk_json_decode_string},
+	{"uuid", offsetof(struct rpc_bdev_bcgroup_create, uuid), spdk_json_decode_uuid, true},
+};
+
+static void
+rpc_bdev_bcgroup_create(struct spdk_jsonrpc_request *request,
+			 const struct spdk_json_val *params)
+{
+	struct rpc_bdev_bcgroup_create req = {NULL};
+	struct spdk_json_write_ctx *w;
+	int rc;
+
+	if (spdk_json_decode_object(params, rpc_bdev_bcgroup_create_decoders,
+				    SPDK_COUNTOF(rpc_bdev_bcgroup_create_decoders),
+				    &req)) {
+		SPDK_ERRLOG("spdk_json_decode_object failed\n");
+		spdk_jsonrpc_send_error_response(request, SPDK_JSONRPC_ERROR_INTERNAL_ERROR,
+						 "spdk_json_decode_object failed");
+		goto cleanup;
+	}
+
+	rc = bdev_bcgroup_create_disk(req.base_bdev_name, req.name, &req.uuid);
+	if (rc != 0) {
+		spdk_jsonrpc_send_error_response(request, rc, spdk_strerror(-rc));
+		goto cleanup;
+	}
+
+	w = spdk_jsonrpc_begin_result(request);
+	spdk_json_write_string(w, req.name);
+	spdk_jsonrpc_end_result(request, w);
+
+cleanup:
+	free_rpc_bdev_bcgroup_create(&req);
+}
+
+struct rpc_bdev_bcgroup_delete {
+	char *name;
+};
+
+static void
+free_rpc_bdev_bcgroup_delete(struct rpc_bdev_bcgroup_delete *req)
+{
+	free(req->name);
+}
+
+static const struct spdk_json_object_decoder rpc_bdev_bcgroup_delete_decoders[] = {
+	{"name", offsetof(struct rpc_bdev_bcgroup_delete, name), spdk_json_decode_string},
+};
+
+static void
+rpc_bdev_bcgroup_delete_cb(void *cb_arg, int bdeverrno)
+{
+	struct spdk_jsonrpc_request *request = cb_arg;
+
+	if (bdeverrno == 0) {
+		spdk_jsonrpc_send_bool_response(request, true);
+	} else {
+		spdk_jsonrpc_send_error_response(request, bdeverrno, spdk_strerror(-bdeverrno));
+	}
+}
+
+static void
+rpc_bdev_bcgroup_delete(struct spdk_jsonrpc_request *request,
+			 const struct spdk_json_val *params)
+{
+	struct rpc_bdev_bcgroup_delete req = {NULL};
+
+	if (spdk_json_decode_object(params, rpc_bdev_bcgroup_delete_decoders,
+				    SPDK_COUNTOF(rpc_bdev_bcgroup_delete_decoders),
+				    &req)) {
+		SPDK_ERRLOG("spdk_json_decode_object failed\n");
+		spdk_jsonrpc_send_error_response(request, SPDK_JSONRPC_ERROR_INTERNAL_ERROR,
+						 "spdk_json_decode_object failed");
+		goto cleanup;
+	}
+
+	bdev_bcgroup_delete_disk(req.name, rpc_bdev_bcgroup_delete_cb, request);
+
+cleanup:
+	free_rpc_bdev_bcgroup_delete(&req);
+}
+
+static void
+rpc_bdev_bcgroup_io_stat(struct spdk_jsonrpc_request *request, const struct spdk_json_val *params)
+{
+    struct spdk_json_write_ctx *w;
+    struct vbdev_bcgroup *node;
+
+    w = spdk_jsonrpc_begin_result(request);
+    spdk_json_write_array_begin(w);
+
+    TAILQ_FOREACH(node, &g_mq_nodes, link) {
+        if (node->config_weight > 0 || node->config_target_lat_us > 0) {
+            spdk_json_write_object_begin(w);
+            spdk_json_write_named_string(w, "device", spdk_bdev_get_name(&node->mq_bdev));
+            
+            spdk_json_write_named_object_begin(w, "stat");
+            spdk_json_write_named_uint64(w, "rbytes", node->total_rbytes);
+            spdk_json_write_named_uint64(w, "wbytes", node->total_wbytes);
+            spdk_json_write_named_uint64(w, "rios", node->total_rios);
+            spdk_json_write_named_uint64(w, "wios", node->total_wios);
+
+            spdk_json_write_named_uint64(w, "iops", node->measured_iops);
+            spdk_json_write_named_uint64(w, "lat_us", node->measured_avg_latency);
+            spdk_json_write_named_uint64(w, "qos_limit", node->current_run_limit);
+            
+            spdk_json_write_object_end(w);
+            spdk_json_write_object_end(w); 
+        }
+    }
+
+    spdk_json_write_array_end(w);
+    spdk_jsonrpc_end_result(request, w);
+}
+
+static void
+rpc_bdev_bcgroup_io_pressure(struct spdk_jsonrpc_request *request, const struct spdk_json_val *params)
+{
+    struct spdk_json_write_ctx *w;
+    struct vbdev_bcgroup *node;
+    char pct_str[32];
+
+    w = spdk_jsonrpc_begin_result(request);
+    spdk_json_write_array_begin(w);
+
+    TAILQ_FOREACH(node, &g_mq_nodes, link) {
+        if (node->config_weight > 0 || node->config_target_lat_us > 0) {
+            double pressure_pct = 0.0;
+            if (node->total_ticks > 0) {
+                pressure_pct = ((double)node->pressure_ticks / node->total_ticks) * 100.0;
+            }
+            snprintf(pct_str, sizeof(pct_str), "%.2f", pressure_pct);
+
+            spdk_json_write_object_begin(w);
+            spdk_json_write_named_string(w, "device", spdk_bdev_get_name(&node->mq_bdev));
+            
+            spdk_json_write_named_object_begin(w, "pressure");
+            spdk_json_write_named_string(w, "some_avg", pct_str);
+            spdk_json_write_named_uint64(w, "pressure_ticks", node->pressure_ticks);
+            spdk_json_write_object_end(w); 
+            
+            spdk_json_write_object_end(w); 
+        }
+    }
+
+    spdk_json_write_array_end(w);
+    spdk_jsonrpc_end_result(request, w);
+}
+
+/* register RPC command */
+SPDK_RPC_REGISTER("bdev_bcgroup_io_stat", rpc_bdev_bcgroup_io_stat, SPDK_RPC_RUNTIME)
+SPDK_RPC_REGISTER("bdev_bcgroup_io_pressure", rpc_bdev_bcgroup_io_pressure, SPDK_RPC_RUNTIME)
+SPDK_RPC_REGISTER("bdev_bcgroup_create", rpc_bdev_bcgroup_create, SPDK_RPC_RUNTIME)
+SPDK_RPC_REGISTER("bdev_bcgroup_delete", rpc_bdev_bcgroup_delete, SPDK_RPC_RUNTIME)
