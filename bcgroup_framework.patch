+
+/*
+ * This is a simple example of a virtual block device module that passes IO
+ * down to a bdev (or bdevs) that its configured to attach to.
+ */
+
+#include "spdk/stdinc.h"
+#include "vbdev_bcgroup.h"
+#include "spdk/rpc.h"
+#include "spdk/env.h"
+#include "spdk/endian.h"
+#include "spdk/string.h"
+#include "spdk/thread.h"
+#include "spdk/util.h"
+#include "spdk/bdev_module.h"
+#include "spdk/log.h"
+
+/* This namespace UUID was generated using uuid_generate() method. */
+#define BDEV_BCGROUP_NAMESPACE_UUID "7e25812e-c8c0-4d3f-8599-16d790555b85"
+// change : poller define
+#define MAX_LOW_PRIO_PER_POLL 2
+/* config path */
+#define IOPS_CONFIG_FILE "module/bdev/bcgroup/io.max"
+#define LATENCY_CONFIG_FILE "module/bdev/bcgroup/io.latency"
+#define WEIGHT_CONFIG_FILE "module/bdev/bcgroup/io.weight"
+/* for weight */
+#define DEFAULT_IO_WEIGHT 100
+#define MIN_IO_WEIGHT 0
+#define MAX_IO_WEIGHT 10000
+/* other define */
+#define MAX_BURST_TOKENS 128 
+#define IOPS_UNLIMITED_VAL 1000000
+
+static int vbdev_bcgroup_init(void);
+static int vbdev_bcgroup_get_ctx_size(void);
+static void vbdev_bcgroup_examine(struct spdk_bdev *bdev);
+static void vbdev_bcgroup_finish(void);
+static int vbdev_bcgroup_config_json(struct spdk_json_write_ctx *w);
+
+static struct spdk_bdev_module bcgroup_if = {
+	.name = "bcgroup",
+	.module_init = vbdev_bcgroup_init,
+	.get_ctx_size = vbdev_bcgroup_get_ctx_size,
+	// 0223 : for fio delete
+	.examine_config = vbdev_bcgroup_examine,
+	.module_fini = vbdev_bcgroup_finish,
+	.config_json = vbdev_bcgroup_config_json
+};
+
+SPDK_BDEV_MODULE_REGISTER(bcgroup, &bcgroup_if)
+
+/* List of mq_bdev names and their base bdevs via configuration file.
+ * Used so we can parse the conf once at init and use this list in examine().
+ */
+struct bdev_names {
+	char			*vbdev_name;
+	char			*bdev_name;
+	struct spdk_uuid	uuid;
+	TAILQ_ENTRY(bdev_names)	link;
+};
+static TAILQ_HEAD(, bdev_names) g_bdev_names = TAILQ_HEAD_INITIALIZER(g_bdev_names);
+
+/* List of virtual bdevs and associated info for each. */
+/*
+struct vbdev_bcgroup {
+	struct spdk_bdev		*base_bdev; 
+	struct spdk_bdev_desc	*base_desc; 
+	struct spdk_bdev		mq_bdev;    
+	TAILQ_ENTRY(vbdev_bcgroup)	link;
+	struct spdk_thread		*thread;    
+
+	uint64_t config_target_lat_us; 
+    uint64_t measured_avg_latency; 
+	uint64_t config_weight; 
+    uint64_t measured_iops;
+	uint64_t current_run_limit;
+
+	// for stat, pressure 
+	uint64_t total_rbytes;
+    uint64_t total_wbytes;
+    uint64_t total_rios;
+    uint64_t total_wios;
+    uint64_t pressure_ticks;
+    uint64_t total_ticks;
+};*/
+
+struct mq_node_list g_mq_nodes = TAILQ_HEAD_INITIALIZER(g_mq_nodes);
+
+/* The pt vbdev channel struct. It is allocated and freed on my behalf by the io channel code.
+ * If this vbdev needed to implement a poller or a queue for IO, this is where those things
+ * would be defined. This bcgroup bdev doesn't actually need to allocate a channel, it could
+ * simply pass back the channel of the bdev underneath it but for example purposes we will
+ * present its own to the upper layers.
+ */
+
+TAILQ_HEAD(mq_io_queue, mq_bdev_io);
+
+struct mq_io_channel {
+    struct spdk_io_channel  *base_ch; 
+    struct mq_io_queue      io_queue;
+    struct spdk_poller      *poller;
+	struct vbdev_bcgroup     *mq_node; // global
+
+    /* io.max */
+	char                    bdev_name[64];
+    uint64_t                config_max_iops;
+	uint64_t                config_max_bps;
+
+	int64_t                 iops_token_balance;   
+    int64_t                 bps_token_balance;  
+
+	uint64_t                iops_ticks_remainder; 
+    uint64_t                bps_ticks_remainder;  
+    uint64_t                last_update_time; 
+	uint64_t                stat_bytes_this_sec;
+	/* io.latency */
+	uint64_t                current_run_iops;   // 動態運行上限 (Kp 控制後)
+    uint64_t                config_target_lat_us;
+	/* io.weight */
+    uint64_t                config_weight;
+    /* check time */
+    uint64_t                last_config_check_time; 
+    uint64_t                config_check_interval;
+	uint64_t                last_log_time;
+    uint64_t                log_interval;  
+    /* 單一 Bdev 統計 (合併了原本的高低優先權) */
+    uint64_t                stat_total_latency;
+    uint64_t                stat_io_count;
+    uint64_t                total_rbytes;
+    uint64_t                total_wbytes;
+    uint64_t                total_rios;
+    uint64_t                total_wios;
+};
+
+/* Just for fun, this mq_bdev module doesn't need it but this is essentially a per IO
+ * context that we get handed by the bdev layer.
+ */
+struct mq_bdev_io {
+	/* bdev related */
+	struct spdk_io_channel *ch;
+	struct spdk_bdev_io *bdev_io;
+	TAILQ_ENTRY(mq_bdev_io) link;
+	uint64_t submit_tsc;
+};
+
+static void vbdev_bcgroup_submit_request(struct spdk_io_channel *ch, struct spdk_bdev_io *bdev_io);
+static void _bcgroup_forward_io(struct mq_io_channel *mq_ch, struct spdk_bdev_io *bdev_io);
+static int bcgroup_poller(void *arg);
+
+
+/* Callback for unregistering the IO device. */
+static void
+_device_unregister_cb(void *io_device)
+{
+	struct vbdev_bcgroup *mq_node  = io_device;
+
+	/* Done with this mq_node. */
+	free(mq_node->mq_bdev.name);
+	free(mq_node);
+}
+
+/* Wrapper for the bdev close operation. */
+static void
+_vbdev_bcgroup_destruct(void *ctx)
+{
+	struct spdk_bdev_desc *desc = ctx;
+
+	spdk_bdev_close(desc);
+}
+
+/* Called after we've unregistered following a hot remove callback.
+ * Our finish entry point will be called next.
+ */
+static int
+vbdev_bcgroup_destruct(void *ctx)
+{
+	struct vbdev_bcgroup *mq_node = (struct vbdev_bcgroup *)ctx;
+
+	/* It is important to follow this exact sequence of steps for destroying
+	 * a vbdev...
+	 */
+
+	TAILQ_REMOVE(&g_mq_nodes, mq_node, link);
+
+	/* Unclaim the underlying bdev. */
+	spdk_bdev_module_release_bdev(mq_node->base_bdev);
+
+	/* Close the underlying bdev on its same opened thread. */
+	if (mq_node->thread && mq_node->thread != spdk_get_thread()) {
+		spdk_thread_send_msg(mq_node->thread, _vbdev_bcgroup_destruct, mq_node->base_desc);
+	} else {
+		spdk_bdev_close(mq_node->base_desc);
+	}
+
+	/* Unregister the io_device. */
+	spdk_io_device_unregister(mq_node, _device_unregister_cb);
+
+	return 0;
+}
+
+/* Completion callback for IO that were issued from this bdev. The original bdev_io
+ * is passed in as an arg so we'll complete that one with the appropriate status
+ * and then free the one that this module issued.
+ */
+static void
+_mq_complete_io(struct spdk_bdev_io *bdev_io, bool success, void *cb_arg)
+{
+	// change : io complete
+	/* bdev_io: (Malloc) complete child I/O
+     * cb_arg:  (MyQos) parent I/O
+     */
+    struct spdk_bdev_io *parent_io = cb_arg;
+
+	/* use parent_io find IO Channel */
+    struct spdk_io_channel *ch_base = spdk_bdev_io_get_io_channel(parent_io);
+    /* get context (struct mq_io_channel) */
+    struct mq_io_channel *mq_ch = spdk_io_channel_get_ctx(ch_base);
+	/* get current time */
+    uint64_t now = spdk_get_ticks();
+    /* get submit time from driver_ctx */
+    struct mq_bdev_io *ctx = (struct mq_bdev_io *)parent_io->driver_ctx;
+    
+    if (ctx->submit_tsc > 0) {
+        uint64_t lat = now - ctx->submit_tsc;
+        uint64_t bytes = 0;
+        
+        if (success && parent_io->bdev) {
+            bytes = parent_io->u.bdev.num_blocks * parent_io->bdev->blocklen;
+        }
+
+        mq_ch->stat_total_latency += lat;
+        mq_ch->stat_io_count++;
+		mq_ch->stat_bytes_this_sec += bytes;
+        
+        if (success) {
+            if (parent_io->type == SPDK_BDEV_IO_TYPE_READ) {
+                mq_ch->total_rbytes += bytes;
+                mq_ch->total_rios++;
+            } else if (parent_io->type == SPDK_BDEV_IO_TYPE_WRITE) {
+                mq_ch->total_wbytes += bytes;
+                mq_ch->total_wios++;
+            }
+        }
+    }
+	/*
+	if (mq_ch->in_flight_ios > 0) {
+        mq_ch->in_flight_ios--; 
+    }*/
+
+    spdk_bdev_io_complete(parent_io, success ? SPDK_BDEV_IO_STATUS_SUCCESS : SPDK_BDEV_IO_STATUS_FAILED);
+    spdk_bdev_free_io(bdev_io);
+}
+
+
+/* Called when someone above submits IO to this pt vbdev. We're simply passing it on here
+ * via SPDK IO calls which in turn allocate another bdev IO and call our cpl callback provided
+ * below along with the original bdev_io so that we can complete it once this IO completes.
+ */
+// change : submit request
+static void
+vbdev_bcgroup_submit_request(struct spdk_io_channel *ch, struct spdk_bdev_io *bdev_io)
+{
+    struct mq_io_channel *mq_ch = spdk_io_channel_get_ctx(ch);
+    struct mq_bdev_io *io_ctx = (struct mq_bdev_io *)bdev_io->driver_ctx;
+
+    /* 記錄 I/O 與進入時間 */
+    io_ctx->bdev_io = bdev_io;
+    io_ctx->submit_tsc = spdk_get_ticks();
+
+    /* 直接推入該 Bdev 專屬的單一佇列 */
+    TAILQ_INSERT_TAIL(&mq_ch->io_queue, io_ctx, link);
+}
+
+/* We'll just call the base bdev and let it answer however if we were more
+ * restrictive for some reason (or less) we could get the response back
+ * and modify according to our purposes.
+ */
+static bool
+vbdev_bcgroup_io_type_supported(void *ctx, enum spdk_bdev_io_type io_type)
+{
+	struct vbdev_bcgroup *mq_node = (struct vbdev_bcgroup *)ctx;
+
+	return spdk_bdev_io_type_supported(mq_node->base_bdev, io_type);
+}
+
+/* We supplied this as an entry point for upper layers who want to communicate to this
+ * bdev.  This is how they get a channel. We are passed the same context we provided when
+ * we created our PT vbdev in examine() which, for this bdev, is the address of one of
+ * our context nodes. From here we'll ask the SPDK channel code to fill out our channel
+ * struct and we'll keep it in our PT node.
+ */
+static struct spdk_io_channel *
+vbdev_bcgroup_get_io_channel(void *ctx)
+{
+	struct vbdev_bcgroup *mq_node = (struct vbdev_bcgroup *)ctx;
+	struct spdk_io_channel *mq_ch = NULL;
+
+	/* The IO channel code will allocate a channel for us which consists of
+	 * the SPDK channel structure plus the size of our mq_io_channel struct
+	 * that we passed in when we registered our IO device. It will then call
+	 * our channel create callback to populate any elements that we need to
+	 * update.
+	 */
+	mq_ch = spdk_get_io_channel(mq_node);
+
+	return mq_ch;
+}
+
+/* This is the output for bdev_get_bdevs() for this vbdev */
+static int
+vbdev_bcgroup_dump_info_json(void *ctx, struct spdk_json_write_ctx *w)
+{
+	struct vbdev_bcgroup *mq_node = (struct vbdev_bcgroup *)ctx;
+
+	spdk_json_write_name(w, "bcgroup");
+	spdk_json_write_object_begin(w);
+	spdk_json_write_named_string(w, "name", spdk_bdev_get_name(&mq_node->mq_bdev));
+	spdk_json_write_named_string(w, "base_bdev_name", spdk_bdev_get_name(mq_node->base_bdev));
+	spdk_json_write_object_end(w);
+
+	return 0;
+}
+
+/* This is used to generate JSON that can configure this module to its current state. */
+static int
+vbdev_bcgroup_config_json(struct spdk_json_write_ctx *w)
+{
+	struct vbdev_bcgroup *mq_node;
+
+	TAILQ_FOREACH(mq_node, &g_mq_nodes, link) {
+		const struct spdk_uuid *uuid = spdk_bdev_get_uuid(&mq_node->mq_bdev);
+
+		spdk_json_write_object_begin(w);
+		spdk_json_write_named_string(w, "method", "bdev_bcgroup_create");
+		spdk_json_write_named_object_begin(w, "params");
+		spdk_json_write_named_string(w, "base_bdev_name", spdk_bdev_get_name(mq_node->base_bdev));
+		spdk_json_write_named_string(w, "name", spdk_bdev_get_name(&mq_node->mq_bdev));
+		if (!spdk_uuid_is_null(uuid)) {
+			spdk_json_write_named_uuid(w, "uuid", uuid);
+		}
+		spdk_json_write_object_end(w);
+		spdk_json_write_object_end(w);
+	}
+	return 0;
+}
+
+// change : forward io
+static void
+_bcgroup_forward_io(struct mq_io_channel *mq_ch, struct spdk_bdev_io *bdev_io)
+{
+	//mq_ch->in_flight_ios++;
+    struct vbdev_bcgroup *mq_node = SPDK_CONTAINEROF(bdev_io->bdev, struct vbdev_bcgroup, mq_bdev);
+    int rc = 0;
+
+    switch (bdev_io->type) {
+    case SPDK_BDEV_IO_TYPE_READ:
+        rc = spdk_bdev_readv_blocks(mq_node->base_desc, mq_ch->base_ch,
+                                    bdev_io->u.bdev.iovs, bdev_io->u.bdev.iovcnt,
+                                    bdev_io->u.bdev.offset_blocks,
+                                    bdev_io->u.bdev.num_blocks,
+                                    _mq_complete_io, bdev_io);
+        break;
+    case SPDK_BDEV_IO_TYPE_WRITE:
+        rc = spdk_bdev_writev_blocks(mq_node->base_desc, mq_ch->base_ch,
+                                     bdev_io->u.bdev.iovs, bdev_io->u.bdev.iovcnt,
+                                     bdev_io->u.bdev.offset_blocks,
+                                     bdev_io->u.bdev.num_blocks,
+                                     _mq_complete_io, bdev_io);
+        break;
+    case SPDK_BDEV_IO_TYPE_UNMAP:
+        rc = spdk_bdev_unmap_blocks(mq_node->base_desc, mq_ch->base_ch,
+                                    bdev_io->u.bdev.offset_blocks,
+                                    bdev_io->u.bdev.num_blocks,
+                                    _mq_complete_io, bdev_io);
+        break;
+    case SPDK_BDEV_IO_TYPE_RESET:
+        rc = spdk_bdev_reset(mq_node->base_desc, mq_ch->base_ch,
+                             _mq_complete_io, bdev_io);
+        break;
+    case SPDK_BDEV_IO_TYPE_FLUSH:
+        rc = spdk_bdev_flush_blocks(mq_node->base_desc, mq_ch->base_ch,
+                                    bdev_io->u.bdev.offset_blocks,
+                                    bdev_io->u.bdev.num_blocks,
+                                    _mq_complete_io, bdev_io);
+        break;
+    default:
+        SPDK_ERRLOG("Unsupported IO type: %d\n", bdev_io->type);
+        spdk_bdev_io_complete(bdev_io, SPDK_BDEV_IO_STATUS_FAILED);
+        return;
+    }
+
+    if (rc != 0) {
+        SPDK_ERRLOG("Forward IO failed, rc=%d\n", rc);
+        spdk_bdev_io_complete(bdev_io, SPDK_BDEV_IO_STATUS_FAILED);
+    }
+}
+
+static int
+bcgroup_poller(void *arg)
+{
+    struct mq_io_channel *mq_ch = arg;
+    struct mq_bdev_io *io_ctx;
+    int work_done = 0;
+    uint64_t now = spdk_get_ticks();
+    uint64_t ticks_per_sec = spdk_get_ticks_hz();
+
+	/* io.pressure */
+	mq_ch->mq_node->total_ticks++;
+    if (!TAILQ_EMPTY(&mq_ch->io_queue)) {
+        mq_ch->mq_node->pressure_ticks++;
+    }
+
+    /* read file */
+    if (now - mq_ch->last_config_check_time > mq_ch->config_check_interval) {
+        mq_ch->last_config_check_time = now;
+
+        FILE *f_max = fopen(IOPS_CONFIG_FILE, "r"); 
+        if (f_max) {
+            char line[256];
+            char parsed_name[64];
+            uint64_t parsed_iops, parsed_bps;
+
+            while (fgets(line, sizeof(line), f_max)) {
+                if (sscanf(line, " %63[^,] , iops = %lu , bps = %lu", parsed_name, &parsed_iops, &parsed_bps) == 3) {
+                    if (strcmp(parsed_name, mq_ch->bdev_name) == 0) {
+                        if (parsed_iops != mq_ch->config_max_iops || parsed_bps != mq_ch->config_max_bps) {
+                            SPDK_NOTICELOG("[%s] IO.MAX Change : IOPS -> %lu, BPS -> %lu\n", 
+                                           mq_ch->bdev_name, parsed_iops, parsed_bps);
+                            mq_ch->config_max_iops = parsed_iops;
+                            mq_ch->config_max_bps = parsed_bps;
+                        }
+                        break; 
+                    }
+                }
+            }
+            fclose(f_max);
+        }
+
+		FILE *f_lat = fopen(LATENCY_CONFIG_FILE, "r");
+        if (f_lat) {
+            char line[256]; char p_name[64]; uint64_t p_val;
+            while (fgets(line, sizeof(line), f_lat)) {
+                if (sscanf(line, "%63[^=]=%lu", p_name, &p_val) == 2) {
+                    if (strcmp(p_name, mq_ch->bdev_name) == 0) {
+                        if (p_val != mq_ch->config_target_lat_us) {
+                            SPDK_NOTICELOG("[%s] IO.LATENCY : %lu -> %lu us\n", 
+                                           mq_ch->bdev_name, mq_ch->config_target_lat_us, p_val);
+                            mq_ch->config_target_lat_us = p_val;
+                            mq_ch->mq_node->config_target_lat_us = p_val;
+                        }
+                        break;
+                    }
+                }
+            }
+            fclose(f_lat);
+        }
+
+		FILE *f_wt = fopen(WEIGHT_CONFIG_FILE, "r");
+        if (f_wt) {
+            char line[256]; char p_name[64]; uint64_t p_val;
+            while (fgets(line, sizeof(line), f_wt)) {
+                if (sscanf(line, "%63[^=]=%lu", p_name, &p_val) == 2) {
+                    if (strcmp(p_name, mq_ch->bdev_name) == 0) {
+                        if (p_val <= MIN_IO_WEIGHT) p_val = MIN_IO_WEIGHT;
+                        if (p_val > MAX_IO_WEIGHT) p_val = MAX_IO_WEIGHT;
+                        
+                        if (p_val != mq_ch->config_weight) {
+                            SPDK_NOTICELOG("[%s] IO.WEIGHT Change: %lu -> %lu\n", 
+                                           mq_ch->bdev_name, mq_ch->config_weight, p_val);
+                            mq_ch->config_weight = p_val;
+                        }
+                        break;
+                    }
+                }
+            }
+            fclose(f_wt);
+        }
+    }
+
+	/* Log, io.latency */
+	if (now - mq_ch->last_log_time > mq_ch->log_interval) {
+        uint64_t delta_ticks = now - mq_ch->last_log_time;
+        mq_ch->last_log_time = now;
+
+        if (mq_ch->stat_io_count > 0) {
+            uint64_t real_iops = (mq_ch->stat_io_count * ticks_per_sec) / delta_ticks;
+            uint64_t avg_lat_us = ((mq_ch->stat_total_latency / mq_ch->stat_io_count) * 1000000) / ticks_per_sec;
+            
+            mq_ch->mq_node->measured_avg_latency = avg_lat_us;
+            mq_ch->mq_node->measured_iops = real_iops;
+            mq_ch->mq_node->config_weight = mq_ch->config_weight;
+			mq_ch->mq_node->current_run_limit = mq_ch->current_run_iops;
+
+			/* io.stat */
+			mq_ch->mq_node->total_rbytes = mq_ch->total_rbytes;
+            mq_ch->mq_node->total_wbytes = mq_ch->total_wbytes;
+            mq_ch->mq_node->total_rios = mq_ch->total_rios;
+            mq_ch->mq_node->total_wios = mq_ch->total_wios;
+
+            uint64_t final_limit = IOPS_UNLIMITED_VAL;
+            if (mq_ch->config_target_lat_us == 0) {
+                
+                /* io.weight */
+                if (mq_ch->config_weight > 0) {
+                    double min_actual_ratio = 999999.0; 
+                    double min_limit_ratio = 999999.0;  
+                    bool all_qos_limited = true;        
+                    bool has_active_nodes = false;
+                    struct vbdev_bcgroup *node;
+
+                    TAILQ_FOREACH(node, &g_mq_nodes, link) {
+                        if (node->measured_iops > 5 && node->config_weight > 0 && node->config_target_lat_us == 0) {
+                            has_active_nodes = true;
+                            double actual_ratio = (double)node->measured_iops / node->config_weight;
+                            if (actual_ratio < min_actual_ratio) {
+                                min_actual_ratio = actual_ratio;
+                            }
+
+                            double limit_ratio;
+                            if (node->current_run_limit == IOPS_UNLIMITED_VAL) {
+                                limit_ratio = actual_ratio;
+                                all_qos_limited = false; 
+                            } else {
+                                limit_ratio = (double)node->current_run_limit / node->config_weight;
+                                if (node->measured_iops < (node->current_run_limit * 90 / 100)) {
+                                    all_qos_limited = false; 
+                                }
+                            }
+
+                            if (limit_ratio < min_limit_ratio) {
+                                min_limit_ratio = limit_ratio;
+                            }
+                        }
+                    }
+
+                    double target_ratio = 0.0;
+
+                    if (has_active_nodes) {
+                        if (all_qos_limited) {
+                            target_ratio = min_limit_ratio * 1.10;
+                        } else {
+                            target_ratio = min_actual_ratio * 1.10;
+                        }
+                    } else {
+                        target_ratio = 50.0;
+                    }
+
+                    uint64_t dta_limit = (uint64_t)(mq_ch->config_weight * target_ratio);
+                    if (all_qos_limited && dta_limit <= mq_ch->current_run_iops) {
+                        dta_limit = mq_ch->current_run_iops + 50; 
+                    }
+
+                    if (dta_limit < 100) dta_limit = 100;
+                    final_limit = dta_limit;
+                }
+
+                /* io.latency */
+                int64_t max_error = -9999999;
+                int64_t worst_target = 0;
+                struct vbdev_bcgroup *node;
+
+                TAILQ_FOREACH(node, &g_mq_nodes, link) {
+                    if (node->config_target_lat_us > 0) {
+                        int64_t target = (int64_t)node->config_target_lat_us;
+                        int64_t error = (int64_t)node->measured_avg_latency - target;
+                        int64_t deadband = (target * 3) / 100;
+                        if (error >= -deadband && error <= deadband) error = 0;
+                        if (error > max_error) { max_error = error; worst_target = target; }
+                    }
+                }
+
+                if (worst_target > 0) {
+                    int64_t Kp_den = 3;
+                    int64_t cur_base = mq_ch->current_run_iops;
+
+                    if (cur_base == IOPS_UNLIMITED_VAL || cur_base > (int64_t)(real_iops * 2)) {
+                        cur_base = (real_iops > 0) ? real_iops : 5000;
+                    }
+
+                    int64_t delta_iops = -((cur_base * max_error) / (worst_target * Kp_den));
+                    if (delta_iops == 0 && max_error != 0) delta_iops = (max_error > 0) ? -10 : 10;
+                    
+                    int64_t kp_limit = cur_base + delta_iops;
+                    if (kp_limit < 10) kp_limit = 10;
+
+                    if ((uint64_t)kp_limit < final_limit) {
+                        final_limit = (uint64_t)kp_limit;
+                    }
+                } else {
+                    if (mq_ch->config_weight == 0 && mq_ch->current_run_iops < IOPS_UNLIMITED_VAL) {
+                        uint64_t kp_recovery = mq_ch->current_run_iops + (mq_ch->current_run_iops * 5) / 100;
+                        if (kp_recovery < 5000) kp_recovery = 5000;
+                        
+                        if (kp_recovery < final_limit) {
+                            final_limit = kp_recovery;
+                        }
+                    }
+                }
+            }
+
+            /* io.max */
+            if (mq_ch->config_max_iops > 0) {
+                if (mq_ch->config_max_iops < final_limit) {
+                    final_limit = mq_ch->config_max_iops;
+                }
+            }
+
+            mq_ch->current_run_iops = final_limit;
+
+			double elapsed_sec = (double)delta_ticks / (double)ticks_per_sec;
+			uint64_t real_mbps = 0;
+			if (elapsed_sec > 0) {
+				real_mbps = (uint64_t)((mq_ch->stat_bytes_this_sec / elapsed_sec) / (1024.0 * 1024.0));
+			}
+			SPDK_NOTICELOG("[%s] %lu IOPS, %lu MB/s | Lat: %lu us | Limit: %lu | Wt: %lu\n",
+						mq_ch->bdev_name, real_iops, real_mbps, avg_lat_us, mq_ch->current_run_iops, mq_ch->config_weight);
+
+            mq_ch->stat_io_count = 0;
+            mq_ch->stat_total_latency = 0;
+            mq_ch->stat_bytes_this_sec = 0;
+            
+        } else {
+            mq_ch->mq_node->measured_avg_latency = 0;
+            mq_ch->mq_node->measured_iops = 0;
+            if (mq_ch->config_max_iops == 0 && mq_ch->config_max_bps == 0 && mq_ch->config_target_lat_us == 0) {
+                mq_ch->current_run_iops = IOPS_UNLIMITED_VAL;
+            }
+            
+            mq_ch->stat_bytes_this_sec = 0;
+        }
+    }
+
+    /* 3. Token Bucket 補充 */
+    uint64_t delta = now - mq_ch->last_update_time;
+    mq_ch->last_update_time = now;
+
+    /* IOPS Token */
+    if (mq_ch->current_run_iops != IOPS_UNLIMITED_VAL && mq_ch->current_run_iops > 0) {
+        uint64_t ticks = delta + mq_ch->iops_ticks_remainder;
+        uint64_t earned_iops = (ticks * mq_ch->current_run_iops) / ticks_per_sec;
+        mq_ch->iops_ticks_remainder = ticks - ((earned_iops * ticks_per_sec) / mq_ch->current_run_iops);
+        
+        mq_ch->iops_token_balance += earned_iops;
+        if (mq_ch->iops_token_balance > MAX_BURST_TOKENS) mq_ch->iops_token_balance = MAX_BURST_TOKENS;
+    }
+
+    /* BPS Token */
+    if (mq_ch->config_max_bps > 0) {
+        uint64_t ticks = delta + mq_ch->bps_ticks_remainder;
+        uint64_t earned_bytes = (ticks * mq_ch->config_max_bps) / ticks_per_sec;
+        mq_ch->bps_ticks_remainder = ticks - ((earned_bytes * ticks_per_sec) / mq_ch->config_max_bps);
+        
+        mq_ch->bps_token_balance += earned_bytes;
+        
+        uint64_t max_burst_bytes = mq_ch->config_max_bps; 
+        if (max_burst_bytes < 1048576) max_burst_bytes = 1048576; 
+        if (mq_ch->bps_token_balance > (int64_t)max_burst_bytes) {
+    		mq_ch->bps_token_balance = (int64_t)max_burst_bytes;
+		}
+    }
+
+    /* 4. 根據 Token 發送 I/O */
+    while (!TAILQ_EMPTY(&mq_ch->io_queue)) {
+        io_ctx = TAILQ_FIRST(&mq_ch->io_queue);
+        
+        /* 取得這個 I/O 實際上到底有多大 (Bytes) */
+        uint64_t io_bytes = io_ctx->bdev_io->u.bdev.num_blocks * io_ctx->bdev_io->bdev->blocklen;
+        if (mq_ch->current_run_iops != IOPS_UNLIMITED_VAL && mq_ch->iops_token_balance <= 0) {
+            break; 
+        }
+
+        if (mq_ch->config_max_bps > 0 && mq_ch->bps_token_balance < (int64_t)io_bytes) {
+            break;
+        }
+
+        TAILQ_REMOVE(&mq_ch->io_queue, io_ctx, link);
+        _bcgroup_forward_io(mq_ch, io_ctx->bdev_io);
+        if (mq_ch->current_run_iops != IOPS_UNLIMITED_VAL) mq_ch->iops_token_balance--;
+        if (mq_ch->config_max_bps > 0) mq_ch->bps_token_balance -= io_bytes;
+        
+        work_done++;
+    }
+
+    return work_done > 0 ? SPDK_POLLER_BUSY : SPDK_POLLER_IDLE;
+}
+
+/* We provide this callback for the SPDK channel code to create a channel using
+ * the channel struct we provided in our module get_io_channel() entry point. Here
+ * we get and save off an underlying base channel of the device below us so that
+ * we can communicate with the base bdev on a per channel basis.  If we needed
+ * our own poller for this vbdev, we'd register it here.
+ */
+static int
+mq_bdev_ch_create_cb(void *io_device, void *ctx_buf)
+{
+    struct mq_io_channel *mq_ch = ctx_buf;
+    struct vbdev_bcgroup *mq_node = io_device;
+    uint64_t ticks_per_sec = spdk_get_ticks_hz();
+    mq_ch->base_ch = spdk_bdev_get_io_channel(mq_node->base_desc);
+    if (!mq_ch->base_ch) return -1;
+
+    mq_ch->mq_node = mq_node; // 綁定全域節點
+    snprintf(mq_ch->bdev_name, sizeof(mq_ch->bdev_name), "%s", spdk_bdev_get_name(&mq_node->mq_bdev));
+    TAILQ_INIT(&mq_ch->io_queue);
+
+	//mq_ch->first_iops_init = true;
+    mq_ch->config_max_iops = 0;
+	mq_ch->config_max_bps = 0;
+    mq_ch->current_run_iops = IOPS_UNLIMITED_VAL;
+	mq_ch->stat_bytes_this_sec = 0;
+    mq_ch->config_target_lat_us = 0;
+	mq_ch->config_weight = DEFAULT_IO_WEIGHT;
+	//mq_ch->in_flight_ios = 0;
+    mq_ch->iops_token_balance = MAX_BURST_TOKENS;
+    mq_ch->bps_token_balance = 1048576;  // 預設先給 1MB 的 BPS 爆發額度
+    mq_ch->iops_ticks_remainder = 0;
+    mq_ch->bps_ticks_remainder = 0;
+
+    mq_ch->last_update_time = spdk_get_ticks();
+    mq_ch->last_config_check_time = spdk_get_ticks();
+    mq_ch->config_check_interval = ticks_per_sec * 1;
+    mq_ch->last_log_time = spdk_get_ticks();
+    mq_ch->log_interval = ticks_per_sec * 1;
+
+    mq_ch->poller = spdk_poller_register(bcgroup_poller, mq_ch, 0);
+    return 0;
+}
+
+/* We provide this callback for the SPDK channel code to destroy a channel
+ * created with our create callback. We just need to undo anything we did
+ * when we created. If this bdev used its own poller, we'd unregister it here.
+ */
+static void
+mq_bdev_ch_destroy_cb(void *io_device, void *ctx_buf)
+{
+	struct mq_io_channel *mq_ch = ctx_buf;
+
+	/* change : 移除 Poller */
+    spdk_poller_unregister(&mq_ch->poller);
+
+	spdk_put_io_channel(mq_ch->base_ch);
+}
+
+/* Create the bcgroup association from the bdev and vbdev name and insert
+ * on the global list. */
+static int
+vbdev_bcgroup_insert_name(const char *bdev_name, const char *vbdev_name,
+			   const struct spdk_uuid *uuid)
+{
+	struct bdev_names *name;
+
+	TAILQ_FOREACH(name, &g_bdev_names, link) {
+		if (strcmp(vbdev_name, name->vbdev_name) == 0) {
+			SPDK_ERRLOG("bcgroup bdev %s already exists\n", vbdev_name);
+			return -EEXIST;
+		}
+	}
+
+	name = calloc(1, sizeof(struct bdev_names));
+	if (!name) {
+		SPDK_ERRLOG("could not allocate bdev_names\n");
+		return -ENOMEM;
+	}
+
+	name->bdev_name = strdup(bdev_name);
+	if (!name->bdev_name) {
+		SPDK_ERRLOG("could not allocate name->bdev_name\n");
+		free(name);
+		return -ENOMEM;
+	}
+
+	name->vbdev_name = strdup(vbdev_name);
+	if (!name->vbdev_name) {
+		SPDK_ERRLOG("could not allocate name->vbdev_name\n");
+		free(name->bdev_name);
+		free(name);
+		return -ENOMEM;
+	}
+
+	spdk_uuid_copy(&name->uuid, uuid);
+	TAILQ_INSERT_TAIL(&g_bdev_names, name, link);
+
+	return 0;
+}
